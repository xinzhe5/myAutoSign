{
  "manifest_version": 3,
  "name": "每日自动签到与账号管理",
  "version": "2.0.2",
  "description": "管理 new-api 与 AnyRouter 账号，支持自动识别账号信息、每日自动签到和辅助打开常用页面。",
  "permissions": [
    "alarms",
    "cookies",
    "declarativeNetRequest",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://linux.do/*",
    "https://anyrouter.top/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "每日自动签到与账号管理",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
