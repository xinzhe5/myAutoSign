{
  "manifest_version": 3,
  "name": "每日自动打开网页与 new-api 签到",
  "version": "1.3.2",
  "description": "按照设定时间每天自动打开 Linux.do 和 AnyRouter 控制台，并可自动执行 new-api 签到。",
  "permissions": [
    "alarms",
    "cookies",
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://linux.do/*",
    "https://anyrouter.top/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "每日自动打开网页与 new-api 签到",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
